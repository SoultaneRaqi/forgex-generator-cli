<%_ if (config.orm === 'mongoose') { _%>
import <%- name %> from './<%- name.toLowerCase() %>.model.js';

<%_ if (options.empty) { _%>
export const customServiceLogic = async () => {
  // Add your custom Mongoose logic here
  return true;
};

<%_ } else { _%>
export const findAll = async (query = {}) => {
  // Basic Pagination Scaffolding
  const page = parseInt(query.page, 10) || 1;
  const limit = parseInt(query.limit, 10) || 10;
  const startIndex = (page - 1) * limit;

  const total = await <%- name %>.countDocuments();
  const data = await <%- name %>.find().skip(startIndex).limit(limit);

  return {
    pagination: { page, limit, total, pages: Math.ceil(total / limit) },
    data
  };
};

export const findById = async (id) => {
  return await <%- name %>.findById(id);
};

export const create = async (payload) => {
  return await <%- name %>.create(payload);
};

export const update = async (id, payload) => {
  return await <%- name %>.findByIdAndUpdate(id, payload, {
    new: true,
    runValidators: true,
  });
};

export const remove = async (id) => {
  return await <%- name %>.findByIdAndDelete(id);
};
<%_ } _%>

