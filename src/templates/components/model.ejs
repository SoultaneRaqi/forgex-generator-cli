<%_ if (config.orm === 'mongoose') { _%>
import mongoose from 'mongoose';

const <%- name.toLowerCase() %>Schema = new mongoose.Schema(
  {
    <%_ if (options.empty) { _%>
    // Define your schema fields here...
    <%_ } else { _%>
    name: {
      type: String,
      required: [true, 'Please provide a name for the <%- name %>'],
      trim: true,
      maxlength: [100, 'Name cannot be more than 100 characters'],
    },
    isActive: {
      type: Boolean,
      default: true,
    },
    // Add your other fields here...
    <%_ } _%>
  },
  {
    timestamps: true,
    <%_ if (!options.empty) { _%>
    toJSON: { virtuals: true },
    toObject: { virtuals: true }
    <%_ } _%>
  }
);

export default mongoose.model('<%- name %>', <%- name.toLowerCase() %>Schema);

<%_ } else if (config.orm === 'sequelize') { _%>
import { DataTypes } from 'sequelize';
import sequelize from '../../core/config/db.js';

const <%- name %> = sequelize.define('<%- name %>', {
  <%_ if (options.empty) { _%>
  // Define your Sequelize columns here...
  // Example:
  // title: { type: DataTypes.STRING, allowNull: false },
  <%_ } else { _%>
  name: {
    type: DataTypes.STRING,
    allowNull: false,
  },
  isActive: {
    type: DataTypes.BOOLEAN,
    defaultValue: true,
  },
  // Add your other columns here...
  <%_ } _%>
}, {
  timestamps: true,
  // tableName: '<%- name.toLowerCase() %>s',
});

export default <%- name %>;

<%_ } else if (config.orm === 'prisma') { _%>
/**
 * ForgeX Notice:
 * You selected Prisma ORM. Define your <%- name %> model in `prisma/schema.prisma`:
 *
 * model <%- name %> {
 *   id        String   @id @default(uuid())
 *   name      String
 *   isActive  Boolean  @default(true)
 *   createdAt DateTime @default(now())
 *   updatedAt DateTime @updatedAt
 * }
 *
 * Then run: npx prisma migrate dev
 */
<%_ } else { _%>
/**
 * <%- name %> Model
 * Add your raw SQL queries or native driver logic here.
 */
<%_ } _%>