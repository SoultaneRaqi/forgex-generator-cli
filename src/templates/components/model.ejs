<%_ if (config.orm === 'mongoose') { _%>
import mongoose from 'mongoose';

const <%- name.toLowerCase() %>Schema = new mongoose.Schema(
  {
    <%_ if (options.empty) { _%>
    // Define your custom schema fields here...
    <%_ } else { _%>
    name: {
      type: String,
      required: [true, 'Please provide a name for the <%- name %>'],
      trim: true,
      maxlength: [100, 'Name cannot be more than 100 characters'],
    },
    isActive: {
      type: Boolean,
      default: true,
    },
    // Add your other fields here...
    <%_ } _%>
  },
  {
    timestamps: true,
    <%_ if (!options.empty) { _%>
    toJSON: { virtuals: true },
    toObject: { virtuals: true }
    <%_ } _%>
  }
);

// Example: Add a pre-save hook for hashing passwords or slugifying names
// <%- name.toLowerCase() %>Schema.pre('save', async function (next) {
//   // console.log('<%- name %> is about to be saved');
//   next();
// });

export default mongoose.model('<%- name %>', <%- name.toLowerCase() %>Schema);

