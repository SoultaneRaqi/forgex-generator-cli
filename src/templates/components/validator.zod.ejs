import { z } from 'zod';

// --- Schemas ---

export const create<%- name %>Schema = z.object({
  body: z.object({
    name: z.string({ required_error: 'Name is required' }).min(1).max(100),
    // Add your other fields here...
  }),
});

export const update<%- name %>Schema = z.object({
  body: z.object({
    name: z.string().min(1).max(100).optional(),
    // Add your other fields here...
  }),
});

// --- Middleware Factory ---

const validate = (schema) => (req, res, next) => {
  const result = schema.safeParse({ body: req.body, params: req.params, query: req.query });

  if (!result.success) {
    const errors = result.error.errors.map((e) => ({
      field: e.path.join('.'),
      message: e.message,
    }));

    return res.status(400).json({
      success: false,
      message: 'Validation failed',
      errors,
    });
  }

  req.validatedData = result.data;
  next();
};

// --- Exported Middleware ---

export const validateCreate<%- name %> = validate(create<%- name %>Schema);
export const validateUpdate<%- name %> = validate(update<%- name %>Schema);