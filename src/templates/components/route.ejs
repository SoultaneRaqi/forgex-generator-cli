import { Router } from 'express';
import * as <%- name.toLowerCase() %>Controller from './<%- name.toLowerCase() %>.controller.js';

// TODO: Import your authentication middleware here
// import { protect, authorize } from '../../core/middlewares/auth.js';

const router = Router();

<%_ if (options.empty) { _%>
// ==========================================
// Route:   /api/v1/<%- name.toLowerCase() %>s/custom
// ==========================================
router.get('/custom', <%- name.toLowerCase() %>Controller.customMethod);

<%_ } else { _%>
// ==========================================
// Route:   /api/v1/<%- name.toLowerCase() %>s
// ==========================================
router.route('/')
  .get(<%- name.toLowerCase() %>Controller.get<%- name %>s)
  .post(
    // protect, 
    // authorize('admin'), 
    <%- name.toLowerCase() %>Controller.create<%- name %>
  );

// ==========================================
// Route:   /api/v1/<%- name.toLowerCase() %>s/:id
// ==========================================
router.route('/:id')
  .get(<%- name.toLowerCase() %>Controller.get<%- name %>ById)
  .put(
    // protect, 
    <%- name.toLowerCase() %>Controller.update<%- name %>
  )
  .delete(
    // protect, 
    // authorize('admin'), 
    <%- name.toLowerCase() %>Controller.delete<%- name %>
  );
<%_ } _%>

export default router;