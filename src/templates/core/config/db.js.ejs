<%_ if (orm === 'mongoose') { _%>
import mongoose from 'mongoose';

export const connectDB = async () => {
  try {
    const conn = await mongoose.connect(process.env.DATABASE_URL);
    console.log(`📦 MongoDB Connected: ${conn.connection.host}`);
  } catch (error) {
    console.error('❌ MongoDB connection failed. Did you update the DATABASE_URL in your .env file?');
  }
};
<%_ } else if (orm === 'prisma') { _%>
import { PrismaClient } from '@prisma/client';

const globalForPrisma = global;

export const prisma = globalForPrisma.prisma || new PrismaClient({
  log: process.env.NODE_ENV === 'development' ? ['query', 'error', 'warn'] : ['error'],
});

if (process.env.NODE_ENV !== 'production') globalForPrisma.prisma = prisma;

export const connectDB = async () => {
  try {
    await prisma.$connect();
    console.log('📦 Prisma Database Connected Successfully');
  } catch (error) {
    console.error('❌ Prisma connection failed. Did you update the DATABASE_URL in your .env file?');
  }
};

export default prisma;
<%_ } else if (orm === 'sequelize') { _%>
import { Sequelize } from 'sequelize';

export const sequelize = new Sequelize(process.env.DATABASE_URL, {
  logging: process.env.NODE_ENV === 'development' ? console.log : false,
  dialectOptions: {
    // Uncomment if using SSL (e.g. production PostgreSQL on cloud providers)
    // ssl: { require: true, rejectUnauthorized: false }
  },
});

export const connectDB = async () => {
  try {
    await sequelize.authenticate();
    console.log('📦 Sequelize Connected Successfully');

    if (process.env.NODE_ENV === 'development') {
      await sequelize.sync({ alter: true });
      console.log('Models synced with database.');
    }
  } catch (error) {
    console.error('❌ Sequelize connection failed. Did you update the DATABASE_URL in your .env file?');
  }
};

export default sequelize;
<%_ } else if (database === 'postgres' && orm === 'none') { _%>
import pkg from 'pg';
const { Pool } = pkg;

export const pool = new Pool({
  connectionString: process.env.DATABASE_URL,
});

export const connectDB = async () => {
  try {
    const client = await pool.connect();
    console.log('📦 PostgreSQL Native Driver Connected');
    client.release();
  } catch (error) {
    console.error('❌ PostgreSQL connection failed. Did you update the DATABASE_URL in your .env file?');
  }
};
<%_ } else if (database === 'mysql' && orm === 'none') { _%>
import mysql from 'mysql2/promise';

export const connectDB = async () => {
  try {
    const connection = await mysql.createConnection(process.env.DATABASE_URL);
    console.log('📦 MySQL Native Driver Connected');
    return connection;
  } catch (error) {
    console.error('❌ MySQL connection failed. Did you update the DATABASE_URL in your .env file?');
  }
};
<%_ } else { _%>
// No database selected.
export const connectDB = async () => {
  console.log('Running without a database connection.');
};
<%_ } _%>