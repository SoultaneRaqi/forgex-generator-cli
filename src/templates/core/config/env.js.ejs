/**
 * Environment Variable Validation
 * Generated by ForgeX — runs on startup and crashes early if required vars are missing.
 */

const required = [
  'PORT',
  'NODE_ENV',
<%_ if (database !== 'none') { _%>
  'DATABASE_URL',
<%_ } _%>
<%_ if (extraPackages && extraPackages.includes('jsonwebtoken')) { _%>
  'JWT_SECRET',
  'JWT_EXPIRE',
<%_ } _%>
];

const missing = required.filter((key) => !process.env[key]);

if (missing.length > 0) {
  console.error('\n[ForgeX] ✖ Missing required environment variables:\n');
  missing.forEach((key) => console.error(`  ✖ ${key}`));
  console.error('\n  Please check your .env file and make sure all variables are set.\n');
  process.exit(1);
}