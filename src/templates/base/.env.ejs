# Application Port
PORT=3000

# Environment Status (development, production, testing)
NODE_ENV=development

<%_ if (database === 'postgres') { _%>
# PostgreSQL Database Connection (Default: Localhost)
DATABASE_URL="postgresql://postgres:password@localhost:5432/<%= projectName %>_db?schema=public"
<%_ } else if (database === 'mysql') { _%>
# MySQL Database Connection (Default: Localhost)
DATABASE_URL="mysql://root:password@localhost:3306/<%= projectName %>_db"
<%_ } else if (database === 'mongodb') { _%>
# MongoDB Connection String (Default: Localhost)
DATABASE_URL="mongodb://localhost:27017/<%= projectName %>_db"
<%_ } else { _%>
# No Database Selected
<%_ } _%>

# JWT Secret Key for Authentication
# Note: Change this to a highly secure random string in production!
JWT_SECRET="forgex_super_secret_development_key_2026"
JWT_EXPIRE="7d"