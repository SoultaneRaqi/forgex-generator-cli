{
  "name": "<%- projectName %>",
  "version": "1.0.0",
  "description": "Auto-generated Express API by ForgeX",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js"
    <%_ if (linting) { _%>,
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/"
    <%_ } _%>
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
    <%_ if (orm === 'prisma') { _%>,
    "@prisma/client": "^5.10.2"
    <%_ } _%>
    <%_ if (orm === 'sequelize') { _%>,
    "sequelize": "^6.37.0"
    <%_ if (database === 'postgres') { _%>,
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4"
    <%_ } else if (database === 'mysql') { _%>,
    "mysql2": "^3.9.0"
    <%_ } _%>
    <%_ } _%>
    <%_ if (database === 'mongodb' && orm === 'mongoose') { _%>,
    "mongoose": "^8.2.0"
    <%_ } _%>
    <%_ if (database === 'postgres' && orm === 'none') { _%>,
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4"
    <%_ } _%>
    <%_ if (database === 'mysql' && orm === 'none') { _%>,
    "mysql2": "^3.9.0"
    <%_ } _%>
    <%_ if (extraPackages && extraPackages.includes('helmet')) { _%>,
    "helmet": "^7.1.0"
    <%_ } _%>
    <%_ if (extraPackages && extraPackages.includes('morgan')) { _%>,
    "morgan": "^1.10.0"
    <%_ } _%>
    <%_ if (extraPackages && extraPackages.includes('zod')) { _%>,
    "zod": "^3.22.4"
    <%_ } _%>
    <%_ if (extraPackages && extraPackages.includes('joi')) { _%>,
    "joi": "^17.12.0"
    <%_ } _%>
    <%_ if (extraPackages && extraPackages.includes('bcrypt')) { _%>,
    "bcrypt": "^5.1.1"
    <%_ } _%>
    <%_ if (extraPackages && extraPackages.includes('jsonwebtoken')) { _%>,
    "jsonwebtoken": "^9.0.2"
    <%_ } _%>
    <%_ if (extraPackages && extraPackages.includes('axios')) { _%>,
    "axios": "^1.6.7"
    <%_ } _%>
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
    <%_ if (orm === 'prisma') { _%>,
    "prisma": "^5.10.2"
    <%_ } _%>
    <%_ if (linting) { _%>,
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "prettier": "^3.0.0"
    <%_ } _%>
  }
}