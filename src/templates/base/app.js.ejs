import express from 'express';
import cors from 'cors';
import dotenv from 'dotenv';
import { notFound } from './core/middlewares/notFound.js';
import { errorHandler } from './core/middlewares/errorHandler.js';
<%- extraPackages.includes('helmet') ? "import helmet from 'helmet';\n" : "" -%>
<%- extraPackages.includes('morgan') ? "import morgan from 'morgan';\n" : "" -%>

dotenv.config();

const app = express();

// Global Middlewares
app.use(cors());
app.use(express.json());
app.use(express.urlencoded({ extended: true }));
<%- extraPackages.includes('helmet') ? "app.use(helmet());\n" : "" -%>
<%- extraPackages.includes('morgan') ? "app.use(morgan('dev'));\n" : "" -%>

// Base Route to verify it works
app.get('/', (req, res) => {
  res.json({ 
    message: 'Welcome to <%- projectName %> API!',
    database: '<%- database %>'
  });
});

// Global Error Handlers
app.use(notFound);
app.use(errorHandler);

export default app;