import express from 'express';
import cors from 'cors';
import { notFound } from './core/middlewares/notFound.js';
import { errorHandler } from './core/middlewares/errorHandler.js';
import centralRouter from './core/routes.js'; // Centralized router hub for all module routes
<%- extraPackages.includes('helmet') ? "import helmet from 'helmet';\n" : "" -%>
<%- extraPackages.includes('morgan') ? "import morgan from 'morgan';\n" : "" -%>



const app = express();

// Global Middlewares
app.use(cors());
app.use(express.json());
app.use(express.urlencoded({ extended: true }));
<%- extraPackages.includes('helmet') ? "app.use(helmet());\n" : "" -%>
<%- extraPackages.includes('morgan') ? "app.use(morgan('dev'));\n" : "" -%>

// Base Route to verify it works
app.get('/', (req, res) => {
  res.json({ 
    message: 'Welcome to <%- projectName %> API!',
    database: '<%- database %>'
  });
});

app.use('/api/v1', centralRouter); // All module routes will be prefixed with /api/v1 for better versioning and organization

// Global Error Handlers
app.use(notFound);
app.use(errorHandler);

export default app;